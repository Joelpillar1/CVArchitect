VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ============================================================
# Dodo Payments — set these as Supabase Edge Function secrets
# Dashboard: Project Settings → Edge Functions → Secrets
# Or CLI: supabase secrets set DODO_PAYMENTS_API_KEY=...
# ============================================================
DODO_PAYMENTS_API_KEY=your_dodo_api_key
DODO_PAYMENTS_ENVIRONMENT=test_mode
DODO_PAYMENTS_WEBHOOK_KEY=your_dodo_webhook_secret

# Product IDs (subscription products in Dodo dashboard)
DODO_SPRINT_PRODUCT_ID=prod_xxx      # Sprint — weekly $2.99
DODO_BUILD_PRODUCT_ID=prod_xxx       # Build — monthly $9.99
DODO_BLUEPRINT_PRODUCT_ID=prod_xxx   # Blueprint — quarterly $29

# Optional aliases also supported:
# DODO_API_KEY, DODO_WEBHOOK_SECRET, DODO_WEBHOOK_KEY
# DODO_MARATHON_PRODUCT_ID → maps to BUILD
# DODO_QUARTERLY_PRODUCT_ID → maps to BLUEPRINT

# App URL — used for OAuth redirects in production; browser uses window.location in dev
VITE_APP_URL=http://localhost:5173
APP_URL=https://cvarchitect.app

# Supabase auto-injects these for Edge Functions; set for local/Vercel fallback:
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Resend Email (server-side only)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=CV Architect <support@cvarchitect.app>

# Loops.so (server-side only)
LOOPS_API_KEY=loops_xxxxxxxxxxxxxxxxxxxxxxxx

# Dodo webhook URL (register in Dodo dashboard):
# https://<project-ref>.supabase.co/functions/v1/dodo-webhook
